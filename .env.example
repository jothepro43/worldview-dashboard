# WorldView Dashboard Configuration

# Cesium Ion Token (Required for 3D Globe & Terrain)
# Get a free token: https://cesium.com/ion/tokens
CESIUM_ION_TOKEN=YOUR_CESIUM_ION_TOKEN

# Google Maps API Key (Required for 3D Tiles)
# Enable "Map Tiles API" in Google Cloud Console
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# OpenSky Network API (Flight Data)
# Register at: https://opensky-network.org
OPENSKY_USERNAME=YOUR_USERNAME
OPENSKY_PASSWORD=YOUR_PASSWORD
# For higher rate limits, use OAuth2 client credentials:
OPENSKY_CLIENT_ID=YOUR_CLIENT_ID
OPENSKY_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Windy.com Webcams API (Optional)
# Get key: https://api.windy.com/webcams
WINDY_WEBCAM_API_KEY=YOUR_WINDY_KEY

# ADS-B Exchange (Optional - RapidAPI)
# Get key: https://rapidapi.com/adsbx/api/adsbexchange-com1
ADSBX_API_KEY=YOUR_RAPIDAPI_KEY

# ADSB.fi (Community Flight Data)
# Set to false to disable
ADSBFI_ENABLED=true
